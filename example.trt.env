########################
NODE_ENV=development
PORT=7000
HOST=0.0.0.0

BASE_URL=http://localhost:7000

DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=trt_parts_db

DB_SYNC=true

DB_SSL=false

JWT_SECRET=super-secret-jwt-key-change-me
JWT_EXPIRES_IN=1d

CORS_ORIGIN=*

SWAGGER_ENABLE=true
SWAGGER_PATH=docs
SWAGGER_USER=admin
SWAGGER_PASS=change-me

SMTP_HOST=smtp.your-mail-host.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-password

CONTACT_EMAIL=contact@trt-parts.com

# Google Analytics (GA4) Measurement ID
# Google Analytics Admin -> Data streams -> Web -> Measurement ID
GA_MEASUREMENT_ID=G-YTZVYJD42G

# GA4 Data API uchun (oxirgi 7 kun statistika olish)
# Admin -> Data streams -> {stream} sahifasida "Идентификатор потока" (ID) chiqadi,
# lekin Data API uchun odatda GA4 Property id kerak bo'ladi. Uni tekshirib qo'ying.
GA4_PROPERTY_ID=14225499754

# Google Analytics GA4 Data API uchun Service Account JSON fayl yo'li
# Masalan: ./ga4-service-account.json (project root ichida bo'lsa)
GA4_SERVICE_ACCOUNT_FILE=./ga4-service-account.json
